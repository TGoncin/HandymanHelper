<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>HandymanHelper Marketplace</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/ENSE-281_Lab7_stylesheet.css">
</head>

<body class="bg-light pb-5">
  <div class="mobile-container">

    <header class="bg-white p-3 border-bottom sticky-top">
      <div class="container">
        <div class="text-center w-100">
          <a href="/marketplace" class="d-inline-block">
            <img id="mainLogo" src="/images/logo.png" alt="Handyman Helper" style="max-height: 70px; width: auto;"
              class="mb-2 mx-auto d-block">
          </a>
        </div>

        <div class="mt-2 mb-1 text-start">
          <small class="text-muted">Hello, <strong>
              <%= currentUser.username %>
            </strong>!</small>
        </div>

        <div class="d-flex gap-2">
          <form action="/marketplace" method="POST" class="flex-grow-1">
            <input type="hidden" name="username" value="<%= currentUser.username %>">
            <div class="input-group shadow-sm">
              <input type="text" name="search" class="form-control" placeholder="Search tasks..."
                value="<%= searchQuery %>">
              <button class="btn btn-search-custom" type="submit">
                <i class="bi bi-search"></i>
              </button>
            </div>
          </form>
          <button class="btn btn-outline-primary" type="button" data-bs-toggle="collapse"
            data-bs-target="#floatingMenu">
            <i class="bi bi-list"></i>
          </button>
        </div>
      </div>
    </header>

    <main class="container mt-4">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="fw-bold mb-0">
          <%= viewMode==='MY_POSTS' ? 'My Posts' : 'Marketplace' %>
        </h3>
        <span class="badge bg-secondary">
          <%= totalAds %> Ads
        </span>
      </div>

      <div class="row g-3">
        <% jobs.forEach(job=> { %>
          <div class="col-12">
            <div class="card shadow-sm job-card-custom h-100">
              <div class="card-body">
                <div class="d-flex justify-content-between">
                  <h5 class="card-title fw-bold text-truncate">
                    <%= job.title %>
                  </h5>
                  <span class="text-success fw-bold">$<%= job.budget %></span>
                </div>
                <p class="card-text text-muted small text-truncate-2">
                  <%= job.description %>
                </p>
                <div class="d-flex justify-content-between align-items-center mt-3">
                  <span class="badge bg-white text-success border border-success">
                    <%= job.status %>
                  </span>
                  <form action="/job-details" method="POST">
                    <input type="hidden" name="username" value="<%= currentUser.username %>">
                    <input type="hidden" name="postId" value="<%= job._id %>">
                    <button type="submit" class="btn btn-sm btn-view-details px-4">View Details</button>
                  </form>
                  <% if (viewMode==='MY_POSTS' || job.client===currentUser.username) { %>
                    <form action="/delete-post" method="POST" class="d-inline">
                      <input type="hidden" name="username" value="<%= currentUser.username %>">
                      <input type="hidden" name="postId" value="<%= job._id %>">
                      <button type="submit" class="btn btn-sm btn-outline-danger border-0"
                        onclick="return confirm('Delete this post?')">
                        <i class="bi bi-trash"></i>
                      </button>
                    </form>
                    <% } %>
                </div>
              </div>
            </div>
          </div>
          <% }) %>
      </div>
    </main>

    <div class="collapse fixed-top w-100 h-100 bg-white shadow-lg overflow-auto" id="floatingMenu"
      style="z-index: 1060; padding-top: 80px;">
      <div class="container py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <h2 class="fw-bold text-primary">Menu</h2>
          <button class="btn-close" type="button" data-bs-toggle="collapse" data-bs-target="#floatingMenu"></button>
        </div>

        <div class="d-flex justify-content-between align-items-center py-3 border-bottom">
          <span class="fw-bold"><i class="bi bi-moon-stars me-2"></i> Dark Mode</span>
          <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" id="darkModeToggle"
              style="transform: scale(1.5); cursor: pointer;">
          </div>
        </div>

        <div class="d-grid gap-3">
          <form action="/marketplace" method="POST">
            <input type="hidden" name="username" value="<%= currentUser.username %>">
            <input type="hidden" name="category" value="General">
            <button type="submit" class="btn btn-outline-secondary w-100 py-3 text-start">
              <i class="bi bi-mailbox me-2"></i> General Posts
            </button>
          </form>

          <div class="accordion" id="filterAccordion">
            <div class="accordion-item border-primary">
              <h2 class="accordion-header">
                <button class="accordion-button collapsed fw-bold text-primary" type="button" data-bs-toggle="collapse"
                  data-bs-target="#filterCollapse">
                  <i class="bi bi-funnel me-2"></i> Filter
                </button>
              </h2>
              <div id="filterCollapse" class="accordion-collapse collapse" data-bs-parent="#filterAccordion">
                <div class="accordion-body d-grid gap-2">

                  <div class="dropdown">
                    <button class="btn btn-light w-100 text-start dropdown-toggle" data-bs-toggle="dropdown">By
                      Price</button>
                    <ul class="dropdown-menu w-100">
                      <li>
                        <form action="/marketplace" method="POST">
                          <input type="hidden" name="username" value="<%= currentUser.username %>">
                          <input type="hidden" name="sort" value="desc">
                          <button type="submit" class="dropdown-item">Highest price</button>
                        </form>
                      </li>
                      <li>
                        <form action="/marketplace" method="POST">
                          <input type="hidden" name="username" value="<%= currentUser.username %>">
                          <input type="hidden" name="sort" value="asc">
                          <button type="submit" class="dropdown-item">Lowest price</button>
                        </form>
                      </li>
                      <li><button class="dropdown-item" type="button">Range</button></li>
                    </ul>
                  </div>
                  <div class="dropdown">
                    <button class="btn btn-light w-100 text-start dropdown-toggle" data-bs-toggle="dropdown">By
                      Category</button>
                    <ul class="dropdown-menu w-100">
                      <% ["Plumbing", "Electrical" , "Carpentry" , "Cleaning" , "General" ].forEach(cat=> { %>
                        <li>
                          <form action="/marketplace" method="POST">
                            <input type="hidden" name="username" value="<%= currentUser.username %>">
                            <input type="hidden" name="category" value="<%= cat %>">
                            <button type="submit" class="dropdown-item">
                              <%= cat %>
                            </button>
                          </form>
                        </li>
                        <% }) %>
                    </ul>
                  </div>

                  <div class="dropdown">
                    <button class="btn btn-light w-100 text-start dropdown-toggle" data-bs-toggle="dropdown">By Bidding
                      with Ending soon</button>
                    <ul class="dropdown-menu w-100">
                      <li><button class="dropdown-item">Biddings Only</button></li>
                      <li><button class="dropdown-item">Ending soon</button></li>
                      <li><button class="dropdown-item">Choose range</button></li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <button class="btn btn-outline-secondary w-100 py-3 text-start">
            <i class="bi bi-mailbox me-2"></i> General Posts
          </button>

          <button class="btn btn-outline-secondary w-100 py-3 text-start">
            <i class="bi bi-person-badge me-2"></i> My Posts
          </button>

          <button class="btn btn-outline-warning w-100 py-3 text-start">
            <i class="bi bi-exclamation-triangle me-2"></i> Report an issue
          </button>

          <button class="btn btn-outline-info w-100 py-3 text-start">
            <i class="bi bi-person-circle me-2"></i> My Account
          </button>

          <hr>
          <a href="/logout" class="btn btn-danger py-3">Logout</a>
        </div>
      </div>
    </div>
  </div>
  <script>
    const body = document.body;
    const mainLogo = document.getElementById('mainLogo');
    const darkModeToggle = document.getElementById('darkModeToggle');

    function updateLogo(isDark) {
      if (mainLogo) {
        mainLogo.src = isDark ? '/images/logo-dark.png' : '/images/logo.png';
      }
    }

    const savedTheme = localStorage.getItem('theme');
    if (savedTheme === 'dark') {
      body.classList.add('dark-mode');
      if (darkModeToggle) darkModeToggle.checked = true;
      updateLogo(true);
    } else {
      updateLogo(false);
    }

    if (darkModeToggle) {
      darkModeToggle.addEventListener('change', () => {
        if (darkModeToggle.checked) {
          body.classList.add('dark-mode');
          localStorage.setItem('theme', 'dark');
          updateLogo(true);
        } else {
          body.classList.remove('dark-mode');
          localStorage.setItem('theme', 'light');
          updateLogo(false);
        }
      });
    }
  </script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>