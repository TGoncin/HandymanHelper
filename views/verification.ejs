<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HandymanHelper - Verify Identity</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/ENSE-281_Lab7_stylesheet.css">
</head>

<body class="bg-light">
    <div class="container py-4">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="text-center mb-4">
                    <a href="/marketplace">
                        <img id="mainLogo" src="/images/logo.png" alt="Handyman Helper"
                            style="max-height: 70px; width: auto;" class="mb-2">
                    </a>
                    <h2 class="fw-bold mt-3 text-primary">Identity Verification</h2>
                    <p class="text-muted">Submit your credentials to unlock bidding.</p>
                </div>
                <hr>

                <form action="/verify" method="post" enctype="multipart/form-data">
                    <input type="hidden" name="username" value="<%= currentUser.username %>">

                    <div class="mb-4">
                        <label class="form-label fw-bold">License Number</label>
                        <input type="text" name="licenseNumber" class="form-control form-control-lg"
                            placeholder="e.g. SK-99823-X" required>
                    </div>

                    <div class="mb-4 text-center">
                        <label class="form-label fw-bold d-block text-start">License Photo</label>
                        <div class="border rounded p-4 bg-white">
                            <i class="bi bi-camera-fill display-4 text-secondary"></i>
                            <input type="file" name="licenseImage" class="form-control mt-2" accept="image/*"
                                capture="camera" required>
                            <small class="text-muted d-block mt-2">Tap to take a photo of your trade license</small>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-3 fw-bold">Submit for Review</button>
                    <a href="/" class="btn btn-link w-100 mt-2 text-decoration-none">Back to Marketplace</a>
                </form>
            </div>
        </div>
    </div>
    <script>
        const body = document.body;
        const mainLogo = document.getElementById('mainLogo');
        const darkModeToggle = document.getElementById('darkModeToggle');

        function updateLogo(isDark) {
            if (mainLogo) {
                mainLogo.src = isDark ? '/images/logo-dark.png' : '/images/logo.png';
            }
        }

        const savedTheme = localStorage.getItem('theme');
        if (savedTheme === 'dark') {
            body.classList.add('dark-mode');
            if (darkModeToggle) darkModeToggle.checked = true;
            updateLogo(true);
        } else {
            updateLogo(false);
        }

        if (darkModeToggle) {
            darkModeToggle.addEventListener('change', () => {
                if (darkModeToggle.checked) {
                    body.classList.add('dark-mode');
                    localStorage.setItem('theme', 'dark');
                    updateLogo(true);
                } else {
                    body.classList.remove('dark-mode');
                    localStorage.setItem('theme', 'light');
                    updateLogo(false);
                }
            });
        }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>