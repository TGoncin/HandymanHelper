<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Join HandymanHelper</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/ENSE-281_Lab7_stylesheet.css" />
</head>

<body class="bg-light py-5">
    <div class="container">
        <div class="card shadow-sm mx-auto" style="max-width: 450px;">
            <div class="card-body p-4">
                <div class="text-center mb-3">
                    <a href="/marketplace">
                        <img id="mainLogo" src="/images/logo.png" alt="Handyman Helper"
                            style="max-height: 70px; width: auto;" class="mb-2">
                    </a>
                    <h2 class="fw-bold mt-2">Create Account</h2>
                </div>

                <form action="/register" method="post">
                    <div class="mb-3">
                        <label class="form-label">Account Type</label>
                        <select name="role" class="form-select border-primary fw-bold" required>
                            <option value="CLIENT">I want to hire someone</option>
                            <option value="CONTRACTOR">I am a skilled Contractor</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email Address</label>
                        <input type="email" name="username" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input type="password" name="password" class="form-control" required />
                    </div>

                    <input type="hidden" name="invitecode" value="Note Vote 2026" />

                    <button type="submit" class="btn btn-primary w-100 py-2 mt-2">Sign Up</button>
                </form>

                <p class="text-center mt-4 small">Already joined? <a href="/">Login here</a></p>
            </div>
        </div>
    </div>
    <script>
        const body = document.body;
        const mainLogo = document.getElementById('mainLogo');
        const darkModeToggle = document.getElementById('darkModeToggle');

        function updateLogo(isDark) {
            if (mainLogo) {
                mainLogo.src = isDark ? '/images/logo-dark.png' : '/images/logo.png';
            }
        }

        const savedTheme = localStorage.getItem('theme');
        if (savedTheme === 'dark') {
            body.classList.add('dark-mode');
            if (darkModeToggle) darkModeToggle.checked = true;
            updateLogo(true);
        } else {
            updateLogo(false);
        }

        if (darkModeToggle) {
            darkModeToggle.addEventListener('change', () => {
                if (darkModeToggle.checked) {
                    body.classList.add('dark-mode');
                    localStorage.setItem('theme', 'dark');
                    updateLogo(true);
                } else {
                    body.classList.remove('dark-mode');
                    localStorage.setItem('theme', 'light');
                    updateLogo(false);
                }
            });
        }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>