<div class="card mb-3 shadow-sm border-0">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <h6 class="card-title fw-bold text-primary mb-0">
                <%= post.text.substring(0, 30) %>
                    <%= post.text.length> 30 ? '...' : '' %>
            </h6>
            <span class="badge rounded-pill bg-light text-dark border">
                Bids: <%= post.upvotes.length %>
            </span>
        </div>

        <p class="card-text small text-secondary mb-3">
            <%= post.text %>
        </p>

        <div class="d-flex justify-content-between align-items-center pt-2 border-top">
            <div class="user-info">
                <small class="text-muted d-block">Posted by:</small>
                <span class="fw-semibold small">
                    <%= post.creator.username %>
                </span>
            </div>

            <div class="actions">
                <% if (currentUser.username !==post.creator.username) { %>
                    <form action="/upvote" method="post">
                        <input type="hidden" name="username" value="<%= currentUser.username %>" />
                        <input type="hidden" name="postId" value="<%= post._id %>" />
                        <button type="submit" class="btn btn-primary btn-sm px-4 rounded-pill">
                            <%= post.upvotes.some(u=> u.username === currentUser.username) ? 'Bid Placed' : 'Place Bid'
                                %>
                        </button>
                    </form>
                    <% } else { %>
                        <span class="badge bg-info text-dark">My Job</span>
                        <% } %>
            </div>
        </div>

        <div class="mt-3 p-2 bg-light rounded d-flex justify-content-between align-items-center">
            <small class="text-muted">User Trust Rating:</small>
            <form action="/downvote" method="post" class="m-0">
                <input type="hidden" name="username" value="<%= currentUser.username %>" />
                <input type="hidden" name="postId" value="<%= post._id %>" />
                <button type="submit"
                    class="btn btn-sm <%= post.downvotes.some(u => u.username === currentUser.username) ? 'btn-warning' : 'btn-outline-warning' %>">
                    ★ Verify Experience (<%= post.downvotes.length %>)
                </button>
            </form>
        </div>
    </div>
</div>